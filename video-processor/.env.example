# ============================================
# WINAI Video Processor 환경변수
# ============================================

# 포트 (Railway는 PORT를 자동 주입)
# PORT=3002

# CORS 허용 오리진 — 브라우저 전용 방어. 콤마 구분.
# ALLOWED_ORIGINS=https://winai.kr,http://localhost:3000

# 공유 인증 시크릿 — Next.js 앱과 동일한 값을 사용.
# 이 값이 설정되면 /api/* 경로는 X-API-Secret 헤더 검증을 요구한다.
# ⚠️ 프로덕션에서는 반드시 설정. 없으면 Railway URL만 알면 누구나 호출 가능(개발 모드).
# PROCESSOR_SHARED_SECRET=your_random_shared_secret
