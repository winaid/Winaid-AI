# ============================================
# WINAID Public App 환경변수 (.env.local에 복사하여 사용)
# ============================================

# ── 필수: Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── 필수: Gemini API ──
GEMINI_API_KEY=your_gemini_api_key

# ── 선택: Gemini 백업 키 (멀티키 로테이션) ──
# GEMINI_API_KEY_2=your_backup_key_2
# GEMINI_API_KEY_3=your_backup_key_3

# ── 선택: 크롤러 서버 (말투 학습 크롤링용) ──
# NEXT_PUBLIC_CRAWLER_URL=http://localhost:3001

# ── 선택: 이미지 검색 API ──
# Pexels: https://www.pexels.com/api/ → 무료 즉시 발급
# PEXELS_API_KEY=your_pexels_api_key

# Pixabay: https://pixabay.com/api/docs/ → 무료 가입 후 즉시 발급
# PIXABAY_API_KEY=your_pixabay_api_key

# Google Custom Search: https://console.cloud.google.com → Custom Search API
# + https://cse.google.com/cse/all → 검색 엔진 생성 (이미지 검색 ON)
# GOOGLE_CSE_API_KEY=your_google_cse_api_key
# GOOGLE_CSE_CX=your_google_cse_cx

# ── 선택: Google Cloud Speech-to-Text (AI 자막 생성) ──
# GOOGLE_CLOUD_PROJECT_ID=your_gcp_project_id
# GOOGLE_CLOUD_STT_REGION=us-central1
# GOOGLE_CLOUD_CREDENTIALS_JSON={"type":"service_account",...}
# 또는 파일 경로:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── 선택: Video Processor 서버 (영상 편집 FFmpeg/auto-editor 처리) ──
# Railway에 video-processor 배포 후 URL 설정
# NEXT_PUBLIC_VIDEO_PROCESSOR_URL=https://your-video-processor.railway.app
# video-processor와 공유하는 인증 시크릿 (아무 랜덤 문자열, 양쪽 값 일치 필수)
# 설정 안 하면 video-processor는 개발 모드로 동작(인증 비활성화) — 프로덕션에서는 반드시 설정
# PROCESSOR_SHARED_SECRET=your_random_shared_secret

# ── 선택: Jamendo 무료 음악 API (BGM 검색) ──
# https://developer.jamendo.com 에서 앱 등록 후 Client ID 발급
# JAMENDO_CLIENT_ID=your_jamendo_client_id

# ── 선택: Hugging Face API (AI 음악 생성) ──
# https://huggingface.co/settings/tokens 에서 발급
# HUGGINGFACE_API_KEY=hf_xxxxx

# ── 선택: remove.bg API (이미지 배경 제거) ──
# https://www.remove.bg/api
# REMOVE_BG_API_KEY=your_remove_bg_key

# ── 선택: 네이버 검색 API (블로그/뉴스 검색) ──
# https://developers.naver.com/apps/ → 애플리케이션 등록
# NAVER_CLIENT_ID=your_naver_client_id
# NAVER_CLIENT_SECRET=your_naver_client_secret

# ── 선택: 네이버 검색광고 API (키워드 도구 — 검색량/관련어) ──
# https://searchad.naver.com → 도구 → API 사용 관리
# NAVER_SEARCHAD_API_KEY=your_searchad_api_key
# NAVER_SEARCHAD_SECRET=your_searchad_secret
# NAVER_SEARCHAD_CUSTOMER_ID=your_searchad_customer_id

# ============================================
# Claude (글쓰기 전용. 이미지/검색은 Gemini 유지)
# ============================================
# https://console.anthropic.com/ → Settings → API Keys
ANTHROPIC_API_KEY=
# 선택: 멀티키 로테이션 (rate limit 회피)
ANTHROPIC_API_KEY_2=
ANTHROPIC_API_KEY_3=

# true → 모든 Claude 태스크를 Gemini 로 폴백 (incident 대응용 kill-switch)
LLM_DISABLE_CLAUDE=false

# Task별 provider/model 오버라이드 예시:
# LLM_OVERRIDE_BLOG_FINAL=claude:claude-sonnet-4-6
# LLM_OVERRIDE_PRESS=gemini:gemini-3.1-pro-preview

# Batch polling cron endpoint 보호용 시크릿 (/api/internal/poll-batches 에서 검증)
LLM_BATCH_CRON_SECRET=

# ============================================
# Supabase service role (선택)
# ============================================
# api_usage_logs / llm_batches insert 를 RLS 우회해서 쓰기 위함. 서버 전용.
# 미설정 시 anon key 로 대체 시도 (RLS 로 인해 user_id null insert 가 실패할 수 있음)
# SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# AEO/GEO 진단 도구 — PageSpeed Insights API (선택)
# ============================================
# 없어도 작동 (하루 25회 제한 무키 모드). 설정 시 quota 해제.
# PAGESPEED_API_KEY=

# ============================================
# OpenAI (이미지 생성 gpt-image-2 + AEO/GEO 실측 공용)
# ============================================
# /api/image 가 OpenAI gpt-image-2 로 마이그레이션됨 (2026-04-28).
# 이미지 기능 사용 시 필수. 미설정이면 /api/image 가 500 응답.
# AEO/GEO 진단의 ChatGPT 실측에도 동일 키 사용 — 없으면 ChatGPT 실측만 스킵
# (Gemini grounding 은 기존 GEMINI_API_KEY 재사용. 진단 1회당 ~$0.01~0.02).
# https://platform.openai.com/api-keys 에서 발급.
OPENAI_API_KEY=
# 선택: 멀티키 로테이션 (key1 rate limit / 503 발생 시 자동 다음 키)
# OPENAI_API_KEY_2=
# OPENAI_API_KEY_3=

# 선택: 이미지 모델 오버라이드. 기본 'gpt-image-2'.
# 스냅샷 핀: 'gpt-image-2-2026-04-21' (모델 변경 영향 없이 결과 재현)
# OPENAI_IMAGE_MODEL=gpt-image-2

# 선택: images.edit 분기 활성화 (기본 비활성, '0' 또는 미설정).
# 2026-04-27 시점 openai-node v6.34 의 model validation 버그(이슈 #1844)로
# images.edit 가 gpt-image-2 를 거부 — OpenAI 가 픽스하면 '1' 로 켜기.
# 활성 시 referenceImage / logoBase64 / calendarImage 첨부가 실제 이미지 입력으로 동작.
# OPENAI_IMAGE_EDIT_ENABLED=0
