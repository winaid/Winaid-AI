# ============================================
# WINAID Public App 환경변수 (.env.local에 복사하여 사용)
# ============================================

# ── 필수: Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── 필수: Gemini API ──
GEMINI_API_KEY=your_gemini_api_key

# ── 선택: Gemini 백업 키 (멀티키 로테이션) ──
# GEMINI_API_KEY_2=your_backup_key_2
# GEMINI_API_KEY_3=your_backup_key_3

# ── 선택: 크롤러 서버 (말투 학습 크롤링용) ──
# NEXT_PUBLIC_CRAWLER_URL=http://localhost:3001

# ── 선택: 이미지 검색 API ──
# Pexels: https://www.pexels.com/api/ → 무료 즉시 발급
# PEXELS_API_KEY=your_pexels_api_key

# Google Custom Search: https://console.cloud.google.com → Custom Search API
# + https://cse.google.com/cse/all → 검색 엔진 생성 (이미지 검색 ON)
# GOOGLE_CSE_API_KEY=your_google_cse_api_key
# GOOGLE_CSE_CX=your_google_cse_cx
