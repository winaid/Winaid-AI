{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["iad1"],
  "functions": {
    "api/gemini.js": {
      "maxDuration": 300,
      "memory": 512
    },
    "api/health.js": {
      "maxDuration": 10,
      "memory": 128
    },
    "api/index.js": {
      "maxDuration": 10,
      "memory": 128
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Methods", "value": "POST, GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-Generation-Token, X-Admin-Token" },
        { "key": "Access-Control-Max-Age", "value": "86400" },
        { "key": "Vary", "value": "Origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/gemini", "destination": "/api/gemini" },
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/", "destination": "/api/index" }
  ]
}
