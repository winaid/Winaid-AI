# ── 클라이언트 환경변수 (NEXT_PUBLIC_ 접두사 → 브라우저에 노출) ──

# Supabase (필수! 없으면 앱 시작 불가)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── 서버 사이드 환경변수 (API Route Handler용) ──

# Gemini API
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_API_KEY_2=your_backup_key_2
GENERATION_TOKEN_SECRET=random_secret_for_hmac
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Naver API
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Naver SearchAd API
NAVER_SEARCHAD_CUSTOMER_ID=your_searchad_customer_id
NAVER_SEARCHAD_API_KEY=your_searchad_api_key
NAVER_SEARCHAD_SECRET=your_searchad_secret

# Google Custom Search
GOOGLE_API_KEY=your_google_api_key
GOOGLE_SEARCH_ENGINE_ID=your_google_cx_id
