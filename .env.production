# 프로덕션 백엔드 API URL
# Cloudflare Pages Functions 사용 - 같은 도메인에서 API 제공
# 비워두면 현재 도메인을 사용 (https://story-darugi.com)
VITE_API_URL=

# Gemini US 프록시 URL (Vercel Serverless, iad1 US East)
# 설정되면 1순위로 사용, 실패 시 /api/gemini/generate (Pages Functions) 폴백
VITE_GEMINI_PROXY_URL=https://vercel-proxy-ten-jade.vercel.app/api/gemini
