# 프로덕션 백엔드 API URL
# Cloudflare Pages Functions 사용 - 같은 도메인에서 API 제공
# 비워두면 현재 도메인을 사용 (https://story-darugi.com)
VITE_API_URL=

# Gemini US 프록시 URL (Google Cloud Functions us-central1)
# 설정되면 1순위로 사용, 실패 시 /api/gemini/generate (Pages Functions) 폴백
# GCF 배포 후 URL을 입력: https://us-central1-PROJECT_ID.cloudfunctions.net/gemini-proxy
# Cloudflare Worker는 Smart Placement 불안정으로 더 이상 사용하지 않음
VITE_GEMINI_PROXY_URL=https://us-central1-winaid-461106.cloudfunctions.net/gemini-proxy
