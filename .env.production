# 프로덕션 백엔드 API URL
# Cloudflare Pages Functions 사용 - 같은 도메인에서 API 제공
# 비워두면 현재 도메인을 사용 (https://story-darugi.com)
VITE_API_URL=

# Gemini Proxy Worker URL (US 리전 고정 - Smart Placement)
# 이 값이 있으면 Worker 프록시로 먼저 요청, 실패 시 /api/gemini/generate 폴백
VITE_GEMINI_PROXY_URL=https://gemini-proxy.story-darugi.workers.dev/generate
