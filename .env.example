# Gemini API Keys (여러 개 설정 가능)
# 새로 발급받은 API 키로 교체하세요!
VITE_GEMINI_API_KEY=YOUR_NEW_API_KEY_1
VITE_GEMINI_API_KEY_2=YOUR_NEW_API_KEY_2
# VITE_GEMINI_API_KEY_3=YOUR_NEW_API_KEY_3 (선택)

# Gemini 프록시 URL (메인 프로젝트 내부 Vercel Serverless, iad1 US East)
# ⚠️ 필수! 프로덕션에서는 /api/gemini (같은 프로젝트 내부)
# 로컬 개발 시에는 http://localhost:3000/api/gemini 등으로 설정
VITE_GEMINI_PROXY_URL=/api/gemini

# Supabase (필수! 없으면 앱 시작 불가)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
