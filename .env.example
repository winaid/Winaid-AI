# Gemini API Keys (여러 개 설정 가능)
# 새로 발급받은 API 키로 교체하세요!
VITE_GEMINI_API_KEY=YOUR_NEW_API_KEY_1
VITE_GEMINI_API_KEY_2=YOUR_NEW_API_KEY_2
# VITE_GEMINI_API_KEY_3=YOUR_NEW_API_KEY_3 (선택)

# Gemini US 프록시 URL (Google Cloud Functions gen2, us-central1)
# GCF 배포 후 URL을 입력하세요
# VITE_GEMINI_PROXY_URL=https://us-central1-YOUR_PROJECT.cloudfunctions.net/gemini-proxy
#
# ⚠️ Cloudflare Worker Smart Placement는 지역 제한 우회 불안정.
#    GCF us-central1을 정식 프록시로 사용.

# Supabase (이미 설정되어 있으면 그대로 사용)
# VITE_SUPABASE_URL=https://giiatpxkhponcbduyzci.supabase.co
# VITE_SUPABASE_ANON_KEY=your_supabase_key
