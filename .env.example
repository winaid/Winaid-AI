# 점검 모드 (true로 설정하면 전체 앱이 점검 안내 페이지로 대체됨)
# VITE_MAINTENANCE_MODE=true

# Gemini API Keys (여러 개 설정 가능)
# 새로 발급받은 API 키로 교체하세요!
VITE_GEMINI_API_KEY=YOUR_NEW_API_KEY_1
VITE_GEMINI_API_KEY_2=YOUR_NEW_API_KEY_2
# VITE_GEMINI_API_KEY_3=YOUR_NEW_API_KEY_3 (선택)

# Gemini 프록시 URL (메인 프로젝트 내부 Vercel Serverless, iad1 US East)
# ⚠️ 필수! 프로덕션에서는 /api/gemini (같은 프로젝트 내부)
# 로컬 개발 시에는 http://localhost:3000/api/gemini 등으로 설정
VITE_GEMINI_PROXY_URL=/api/gemini

# 크롤러 서버 URL (Railway 배포, 말투 학습·블로그 크롤링에 필수)
# 로컬: http://localhost:3001 / 프로덕션: https://your-crawler.railway.app
VITE_CRAWLER_URL=http://localhost:3001

# Supabase (필수! 없으면 앱 시작 불가)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── 서버 사이드 환경변수 (Vercel Dashboard에서 설정) ──

# Gemini API (api/gemini.js용, 프론트에 노출 안 됨)
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_API_KEY_2=your_backup_key_2
# GEMINI_API_KEY_3=your_backup_key_3
GENERATION_TOKEN_SECRET=random_secret_for_hmac
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Naver API (api/naver-news, api/naver/search 등)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Naver SearchAd API (api/naver/keyword-stats용)
NAVER_SEARCHAD_CUSTOMER_ID=your_searchad_customer_id
NAVER_SEARCHAD_API_KEY=your_searchad_api_key
NAVER_SEARCHAD_SECRET=your_searchad_secret

# Google Custom Search (api/google/search, api/web-search/search용)
GOOGLE_API_KEY=your_google_api_key
GOOGLE_SEARCH_ENGINE_ID=your_google_cx_id
